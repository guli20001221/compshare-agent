COMPSHARE_SERVICE_PUBLIC_KEY=
COMPSHARE_SERVICE_PRIVATE_KEY=
COMPSHARE_DEFAULT_ROLE_URN=
LLM_API_KEY=
MYSQL_DSN=user:pass@tcp(127.0.0.1:3306)/compshare_agent?parseTime=true&loc=Local&charset=utf8mb4

# Default answer stack.
# USE_INTENT_PLANNER_FOR defaults to resource,monitor,gpu_specs,stock,platform_image,custom_image,community_image.
# Set USE_INTENT_PLANNER_FOR=off only for fallback/debugging.
USE_KNOWLEDGE_RETRIEVAL=curated
RAG_RETRIEVAL_MODE=qwen3_rrf
USE_GROUNDED_RENDERER=llm

# Legacy direct AK/SK; only needed without STS.
COMPSHARE_PUBLIC_KEY=
COMPSHARE_PRIVATE_KEY=
