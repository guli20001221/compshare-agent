#!/bin/sh
set -e

if command -v pwsh >/dev/null 2>&1; then
  PS="pwsh"
elif command -v powershell >/dev/null 2>&1; then
  PS="powershell"
else
  echo "PowerShell is required to run the pre-commit scripts" >&2
  exit 1
fi

"$PS" -NoProfile -ExecutionPolicy Bypass -File scripts/secret_scan.ps1 -Staged
"$PS" -NoProfile -ExecutionPolicy Bypass -File scripts/check_skill_names.ps1
"$PS" -NoProfile -ExecutionPolicy Bypass -File scripts/check_skill_caps.ps1
