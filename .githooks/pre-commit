#!/bin/sh
if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/secret_scan.ps1 -Staged
elif command -v powershell >/dev/null 2>&1; then
  powershell -NoProfile -ExecutionPolicy Bypass -File scripts/secret_scan.ps1 -Staged
else
  echo "PowerShell is required to run scripts/secret_scan.ps1" >&2
  exit 1
fi
