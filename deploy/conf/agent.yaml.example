agent:
  executor: external
  compshare_api_url: "https://api.compshare.cn/"
  # Legacy direct AK/SK. HTTP server mode uses these when STS service
  # credentials are empty (local/demo fallback).
  public_key: "${COMPSHARE_PUBLIC_KEY}"
  private_key: "${COMPSHARE_PRIVATE_KEY}"
  region: "cn-wlcb"
  # project_id 可选。留空时所有 read-only API 调用不带 ProjectId（CompShare
  # 服务端会回退到账号级默认行为）。如需固定项目（mutating tools 如开关机
  # 调度器需要），改为 "${COMPSHARE_PROJECT_ID}"。
  # 注：PR9 之前留空会触发 GetProjectList 自动发现并通过 SetProjectId 写入
  # 共享执行器；那是一条跨 session 串数据的路径，已经移除。运行时不再有
  # mutating setter，ProjectId 只在这里设置一次。
  # 仅支持 ${ENV_VAR} 形式，不支持 ${ENV_VAR:-default} 默认值语法。
  project_id: ""

  llm:
    base_url: "https://api.modelverse.cn/v1"
    api_key: "${LLM_API_KEY}"
    # ds-v4-flash is the W0+ baseline answerer (post-PR-#95 prompt fix passed
    # 5 hard contracts; ~5-10x faster + cheaper than ds-v4-pro). Ops should
    # monitor ~1.86% empty-return rate on hybrid path (P3 watch-list).
    model: "deepseek-v4-flash"

  # Default answer stack is enabled by environment defaults in the binary:
  # USE_INTENT_PLANNER_FOR defaults to
  # resource,monitor,gpu_specs,stock,pricing,platform_image,custom_image,community_image.
  # USE_KNOWLEDGE_RETRIEVAL=curated, RAG_RETRIEVAL_MODE=qwen3_rrf,
  # USE_GROUNDED_RENDERER=llm. Set USE_INTENT_PLANNER_FOR=off,
  # USE_KNOWLEDGE_RETRIEVAL=off, or USE_GROUNDED_RENDERER=off only for
  # debugging/fallback.

  # 0 or omitted uses the built-in defaults for llm / mutating /
  # read_expensive. The user_turn_* and max_tokens_per_turn fields are
  # OPT-IN test-phase guardrails — 0 / omitted = no enforcement (NOT
  # promoted to a default). All counters are in-memory per process:
  # a pod restart resets every tenant's daily counter, and N replicas
  # without sticky routing yield an effective cap of N × the value below.
  # For production rollout, replace with a Redis-backed limiter before
  # raising the replica count.
  rate_limit:
    llm_qps: 5
    llm_daily: 5000
    mutating_qps: 1
    mutating_daily: 50
    read_expensive_qps: 6
    read_expensive_daily: 500
    # Per-tenant cap on user-initiated chat turns (one user_message frame
    # = 1 turn; confirm responses and pings do NOT count).
    user_turn_qps: 2      # max 2 messages/sec per tenant; 0 = no QPS cap
    user_turn_daily: 30   # 0 = no daily cap; 30 is the 2026-05-21 test-phase value
    # Per-turn cap on total LLM tokens (prompt + completion summed across
    # every LLM call in one user turn). 0 = no cap. 50000 covers heavy
    # multi-tool diagnosis turns; observe trace.outcome.total_tokens and
    # tighten once steady-state distribution is known.
    max_tokens_per_turn: 50000

  # HTTP service settings (used by: compshare-agent server).
  # write_timeout must be 0 for SSE streaming connections.
  http:
    listen_addr: "0.0.0.0:8080"
    read_timeout: "30s"
    write_timeout: "0s"
    sse_keepalive_interval: "15s"
    max_input_length: 4000
    pool_capacity: 200
    pool_idle_ttl: "30m"
    # Per-session question-answer pair cap. Once a session has reached this
    # many turns (= 2 * value rows in `messages`), further Chat calls return
    # SessionTurnLimitExceeded and the client must open a new session.
    # Omit or 0 falls back to the built-in default (10).
    max_session_turns: 10
    # Skip the built-in CORS middleware. Default false = agent emits
    # Access-Control-Allow-* headers itself (needed when the front-end dev
    # server on localhost:3000 fetches 127.0.0.1:<port> directly per the
    # front-back-local-debug skill). In production set this to true so the
    # console gateway is the SOLE source of CORS headers — otherwise both
    # agent and gateway add them and the browser rejects the duplicate.
    disable_cors: false

  # MySQL backing store (used by: compshare-agent server).
  # DSN is resolved from ${MYSQL_DSN} env var.
  mysql:
    dsn: "${MYSQL_DSN}"
    max_open_conns: 20
    max_idle_conns: 5
    conn_max_lifetime: "1h"

  # Static metadata returned by GetMeta action.
  # max_input_length should match http.max_input_length.
  meta:
    welcome: "我是优云算力共享平台 AI 助手，可以问我控制台相关问题。"
    suggested_prompts:
      - "我有哪些实例"
      - "4090 现在有库存吗"
      - "创建实例的操作步骤"
    max_input_length: 4000

  # OCR / 截图摘要。用于 SendCSAgentChat 携带 Image 字段时，调 VL 模型
  # 生成结构化截图描述（页面/场景 + 可见文字 + 错误/异常）。描述作为
  # 上下文注入对话，不替代用户问题。
  # 留空 model 则关闭该功能——请求中的 Image 会被忽略。
  # base_url 和 api_key 留空时继承 agent.llm 的值。
  ocr:
    model: ""              # recommended: "qwen3-vl-flash"
    base_url: ""           # inherits from agent.llm.base_url
    api_key: ""            # inherits from agent.llm.api_key
    timeout: "15s"
    max_bytes: 10485760    # 10MB

  # STS (Security Token Service) credential settings (used by: compshare-agent server).
  # service_ak/service_sk are the long-term service credentials used to mint
  # short-lived STS tokens for per-user API calls. Leave them empty to use
  # legacy direct AK/SK fallback before STS permission is granted.
  # default_role_urn is optional; when set it overrides the per-request role derivation.
  sts:
    service_ak: "${COMPSHARE_SERVICE_PUBLIC_KEY}"
    service_sk: "${COMPSHARE_SERVICE_PRIVATE_KEY}"
    url: "https://api.ucloud.cn/"
    role_urn_template: "ucs:iam::%d:role/ucs-service-role/ServiceRoleForCompshare"
    default_role_urn: "${COMPSHARE_DEFAULT_ROLE_URN}"
    default_session_name: "agent-cli"
    duration_seconds: 3600
    refresh_before: "5m"
