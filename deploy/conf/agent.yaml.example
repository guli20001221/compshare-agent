agent:
  executor: external
  compshare_api_url: "https://api.compshare.cn/"
  public_key: "${COMPSHARE_PUBLIC_KEY}"
  private_key: "${COMPSHARE_PRIVATE_KEY}"
  region: "cn-wlcb"
  # project_id 可选。留空时所有 read-only API 调用不带 ProjectId（CompShare
  # 服务端会回退到账号级默认行为）。如需固定项目（mutating tools 如开关机
  # 调度器需要），改为 "${COMPSHARE_PROJECT_ID}"。
  # 注：PR9 之前留空会触发 GetProjectList 自动发现并通过 SetProjectId 写入
  # 共享执行器；那是一条跨 session 串数据的路径，已经移除。运行时不再有
  # mutating setter，ProjectId 只在这里设置一次。
  # 仅支持 ${ENV_VAR} 形式，不支持 ${ENV_VAR:-default} 默认值语法。
  project_id: ""

  llm:
    base_url: "https://api.modelverse.cn/v1"
    api_key: "${LLM_API_KEY}"
    # ds-v4-flash is the W0+ baseline answerer (post-PR-#95 prompt fix passed
    # 5 hard contracts; ~5-10x faster + cheaper than ds-v4-pro). Ops should
    # monitor ~1.86% empty-return rate on hybrid path (P3 watch-list).
    model: "deepseek-v4-flash"

  # 0 or omitted uses the built-in defaults for llm / mutating /
  # read_expensive. The user_turn_* and max_tokens_per_turn fields are
  # OPT-IN test-phase guardrails — 0 / omitted = no enforcement (NOT
  # promoted to a default). All counters are in-memory per process:
  # a pod restart resets every tenant's daily counter, and N replicas
  # without sticky routing yield an effective cap of N × the value below.
  # For production rollout, replace with a Redis-backed limiter before
  # raising the replica count.
  rate_limit:
    llm_qps: 5
    llm_daily: 5000
    mutating_qps: 1
    mutating_daily: 50
    read_expensive_qps: 6
    read_expensive_daily: 500
    # Per-tenant cap on user-initiated chat turns (one user_message frame
    # = 1 turn; confirm responses and pings do NOT count).
    user_turn_qps: 0      # 0 = no QPS cap
    user_turn_daily: 30   # 0 = no daily cap; 30 is the 2026-05-21 test-phase value
    # Per-turn cap on total LLM tokens (prompt + completion summed across
    # every LLM call in one user turn). 0 = no cap. 50000 covers heavy
    # multi-tool diagnosis turns; observe trace.outcome.total_tokens and
    # tighten once steady-state distribution is known.
    max_tokens_per_turn: 50000
