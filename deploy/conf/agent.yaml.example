agent:
  executor: external
  compshare_api_url: "https://api.compshare.cn/"
  # Legacy direct AK/SK — only used when agent.sts is not configured.
  # For HTTP server mode, use agent.sts instead.
  public_key: "${COMPSHARE_PUBLIC_KEY}"
  private_key: "${COMPSHARE_PRIVATE_KEY}"
  region: "cn-wlcb"
  # project_id 可选。留空时所有 read-only API 调用不带 ProjectId（CompShare
  # 服务端会回退到账号级默认行为）。如需固定项目（mutating tools 如开关机
  # 调度器需要），改为 "${COMPSHARE_PROJECT_ID}"。
  # 注：PR9 之前留空会触发 GetProjectList 自动发现并通过 SetProjectId 写入
  # 共享执行器；那是一条跨 session 串数据的路径，已经移除。运行时不再有
  # mutating setter，ProjectId 只在这里设置一次。
  # 仅支持 ${ENV_VAR} 形式，不支持 ${ENV_VAR:-default} 默认值语法。
  project_id: ""

  llm:
    base_url: "https://api.modelverse.cn/v1"
    api_key: "${LLM_API_KEY}"
    # ds-v4-flash is the W0+ baseline answerer (post-PR-#95 prompt fix passed
    # 5 hard contracts; ~5-10x faster + cheaper than ds-v4-pro). Ops should
    # monitor ~1.86% empty-return rate on hybrid path (P3 watch-list).
    model: "deepseek-v4-flash"

  # 0 or omitted uses the built-in defaults.
  rate_limit:
    llm_qps: 5
    llm_daily: 5000
    mutating_qps: 1
    mutating_daily: 50
    read_expensive_qps: 6
    read_expensive_daily: 500

  # HTTP service settings (used by: compshare-agent server).
  # write_timeout must be 0 for SSE streaming connections.
  http:
    listen_addr: "0.0.0.0:8080"
    read_timeout: "30s"
    write_timeout: "0s"
    sse_keepalive_interval: "15s"
    max_input_length: 4000
    pool_capacity: 200
    pool_idle_ttl: "30m"
    # Per-session question-answer pair cap. Once a session has reached this
    # many turns (= 2 * value rows in `messages`), further Chat calls return
    # SessionTurnLimitExceeded and the client must open a new session.
    # Omit or 0 falls back to the built-in default (10).
    max_session_turns: 10

  # MySQL backing store (used by: compshare-agent server).
  # DSN is resolved from ${MYSQL_DSN} env var.
  mysql:
    dsn: "${MYSQL_DSN}"
    max_open_conns: 20
    max_idle_conns: 5
    conn_max_lifetime: "1h"

  # Static metadata returned by GetMeta action.
  # max_input_length should match http.max_input_length.
  meta:
    welcome: "我是优云算力共享平台 AI 助手，可以问我控制台相关问题。"
    suggested_prompts:
      - "我有哪些实例"
      - "4090 现在有库存吗"
      - "创建实例的操作步骤"
    max_input_length: 4000

  # STS (Security Token Service) credential settings (used by: compshare-agent server).
  # service_ak/service_sk are the long-term service credentials used to mint
  # short-lived STS tokens for per-user API calls.
  # default_role_urn is optional; when set it overrides the per-request role derivation.
  sts:
    service_ak: "${COMPSHARE_SERVICE_PUBLIC_KEY}"
    service_sk: "${COMPSHARE_SERVICE_PRIVATE_KEY}"
    url: "https://api.ucloud.cn/"
    role_urn_template: "ucs:iam::%d:role/ucs-service-role/ServiceRoleForCompshare"
    default_role_urn: "${COMPSHARE_DEFAULT_ROLE_URN}"
    default_session_name: "agent-cli"
    duration_seconds: 3600
    refresh_before: "5m"
